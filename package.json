{
  "name": "digitalocean-media-platform",
  "version": "1.0.0",
  "description": "Media sharing and streaming platform for testing DigitalOcean Object Storage performance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=@app/backend",
    "dev:frontend": "npm run dev --workspace=@app/frontend",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=@app/backend",
    "build:frontend": "npm run build --workspace=@app/frontend",
    "db:migrate": "npm run db:migrate --workspace=@app/backend",
    "db:seed": "npm run db:seed --workspace=@app/backend",
    "db:studio": "npm run db:studio --workspace=@app/backend",
    "worker": "npm run worker --workspace=@app/backend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
