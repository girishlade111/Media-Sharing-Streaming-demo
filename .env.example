# ===========================================
# DigitalOcean Media Platform - Environment
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Application
# -------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/media_platform?schema=public

# -------------------------------------------
# Redis (Cache & Queue)
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# DigitalOcean Spaces (S3-compatible)
# -------------------------------------------
DO_SPACES_KEY=your-access-key
DO_SPACES_SECRET=your-secret-key
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_CDN_URL=https://your-bucket.nyc3.cdn.digitaloceanspaces.com

# -------------------------------------------
# Authentication
# -------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-min-32-chars

# -------------------------------------------
# Upload Limits
# -------------------------------------------
MAX_FILE_SIZE=5368709120
MAX_IMAGE_SIZE=10485760
MAX_VIDEO_SIZE=5368709120
MAX_DOCUMENT_SIZE=104857600

# -------------------------------------------
# Video Transcoding
# -------------------------------------------
TRANSCODE_ENABLED=true
TRANSCODE_QUALITIES=1080p,720p,480p,360p

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# CORS
# -------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=debug
